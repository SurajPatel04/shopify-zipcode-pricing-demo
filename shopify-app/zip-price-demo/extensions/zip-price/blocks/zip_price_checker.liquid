<div class="zip-price-widget">
  <label for="zip-code-{{ block.id }}">ZIP Code</label>

  <input
    id="zip-code-{{ block.id }}"
    type="text"
    maxlength="5"
    placeholder="Enter ZIP code"
  >

  <button id="check-price-btn-{{ block.id }}">
    Check Price
  </button>

  <p id="price-result-{{ block.id }}"></p>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const button = document.getElementById("check-price-btn-{{ block.id }}");

    button?.addEventListener("click", async () => {

        const zipCode = document.getElementById("zip-code-{{ block.id }}").value;

        const result = document.getElementById("price-result-{{ block.id }}");

        if (!/^\d{5}$/.test(zipCode)) {
            result.innerHTML = "Please enter a valid 5-digit ZIP code.";
            return;
        }

        result.innerHTML = "Checking...";

        try {

            const response = await fetch(
                "https://shopify-zipcode-pricing-demo-wj6w.vercel.app/api/price",
                {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        zipCode,
                        productId: "{{ block.settings.product.id | default: product.id }}"
                    })
                }
            );

            const data = await response.json();

            if (data.success) {
                const newPrice = data.data.price;
                result.innerHTML = "Price updated successfully.";
                const priceElements = document.querySelectorAll(".price__regular .price-item--regular, .price-item--sale");
                priceElements.forEach(el => {
                    el.textContent = `$${newPrice}`;
                });
            } else {
                result.innerHTML = data.message;
            }

        } catch (err) {
            result.innerHTML = "Unable to fetch price.";
        }

    });
});
</script>

{% schema %}
{
  "name": "ZIP Price Checker",
  "target": "section",
  "settings": [
    { "type": "product", "id": "product", "label": "Product", "autofill": true }
  ]
}
{% endschema %}
